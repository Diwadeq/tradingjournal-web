//@version=6
indicator("TJR Bias Indicator", overlay=true)

// ============================================================================
// INPUTS
// ============================================================================

grp = "Settings"
bias_pos    = input.string("Top Right", "Table Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grp)
bull_color  = input.color(#00e676, "Bullish Color", group=grp)
bear_color  = input.color(#ff3d57, "Bearish Color", group=grp)
neutral_clr = input.color(#a0a0b8, "Neutral Color", group=grp)

// ============================================================================
// BIAS CALCULATION
// ============================================================================

[d_open, d_close] = request.security(syminfo.tickerid, "D", [open, close])
[h4_open, h4_close] = request.security(syminfo.tickerid, "240", [open, close])
[h1_open, h1_close] = request.security(syminfo.tickerid, "60", [open, close])

d_bias  = d_close > d_open ? "BULLISH" : d_close < d_open ? "BEARISH" : "NEUTRAL"
h4_bias = h4_close > h4_open ? "BULLISH" : h4_close < h4_open ? "BEARISH" : "NEUTRAL"
h1_bias = h1_close > h1_open ? "BULLISH" : h1_close < h1_open ? "BEARISH" : "NEUTRAL"

f_clr(bias) =>
    bias == "BULLISH" ? bull_color : bias == "BEARISH" ? bear_color : neutral_clr

// ============================================================================
// TABLE
// ============================================================================

pos = switch bias_pos
    "Top Right"    => position.top_right
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    "Bottom Left"  => position.bottom_left
    => position.top_right

var table tbl = table.new(pos, 2, 4, bgcolor=color.new(#16161f, 0), border_color=color.new(#2a2a3a, 0), border_width=1, frame_color=color.new(#2a2a3a, 0), frame_width=2)

if barstate.islast
    table.cell(tbl, 0, 0, "Timeframe", text_color=#a0a0b8, text_size=size.normal, bgcolor=color.new(#111118, 0))
    table.cell(tbl, 1, 0, "Bias", text_color=#a0a0b8, text_size=size.normal, bgcolor=color.new(#111118, 0))

    table.cell(tbl, 0, 1, "Daily", text_color=#ffffff, text_size=size.normal, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 1, 1, d_bias, text_color=f_clr(d_bias), text_size=size.normal, bgcolor=color.new(#16161f, 0))

    table.cell(tbl, 0, 2, "4H", text_color=#ffffff, text_size=size.normal, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 1, 2, h4_bias, text_color=f_clr(h4_bias), text_size=size.normal, bgcolor=color.new(#16161f, 0))

    table.cell(tbl, 0, 3, "1H", text_color=#ffffff, text_size=size.normal, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 1, 3, h1_bias, text_color=f_clr(h1_bias), text_size=size.normal, bgcolor=color.new(#16161f, 0))
