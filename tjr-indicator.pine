//@version=6
indicator("TJR Bias Indicator", overlay=true, max_boxes_count=200, max_labels_count=200)

// ============================================================================
// INPUTS
// ============================================================================

grp = "Settings"
bias_pos    = input.string("Top Right", "Table Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grp)
pivot_len   = input.int(5, "Pivot Length", minval=2, maxval=20, group=grp)
bull_color  = input.color(#00e676, "Bullish Color", group=grp)
bear_color  = input.color(#ff3d57, "Bearish Color", group=grp)
neutral_clr = input.color(#a0a0b8, "Neutral Color", group=grp)
show_fvg    = input.bool(true, "Show FVGs on Chart", group=grp)

// ============================================================================
// BIAS FUNCTION — Structure + FVG + Sweeps + BOS
// ============================================================================

calc_bias(tf) =>
    tf_high  = request.security(syminfo.tickerid, tf, high)
    tf_low   = request.security(syminfo.tickerid, tf, low)
    tf_close = request.security(syminfo.tickerid, tf, close)
    tf_open  = request.security(syminfo.tickerid, tf, open)
    tf_close1 = request.security(syminfo.tickerid, tf, close[1])

    tf_ph = request.security(syminfo.tickerid, tf, ta.pivothigh(high, pivot_len, pivot_len))
    tf_pl = request.security(syminfo.tickerid, tf, ta.pivotlow(low, pivot_len, pivot_len))

    // --- Swing tracking ---
    var float sh1 = na, var float sh0 = na
    var float sl1 = na, var float sl0 = na

    if not na(tf_ph)
        sh1 := sh0
        sh0 := tf_ph
    if not na(tf_pl)
        sl1 := sl0
        sl0 := tf_pl

    // --- Market Structure (HH/HL/LH/LL) ---
    hh = not na(sh0) and not na(sh1) and sh0 > sh1
    hl = not na(sl0) and not na(sl1) and sl0 > sl1
    lh = not na(sh0) and not na(sh1) and sh0 < sh1
    ll = not na(sl0) and not na(sl1) and sl0 < sl1

    struct_score = 0.0
    struct_score += hh ? 1.0 : lh ? -1.0 : 0.0
    struct_score += hl ? 1.0 : ll ? -1.0 : 0.0

    // --- Break of Structure (BOS) ---
    // Bullish BOS: close breaks above last swing high
    // Bearish BOS: close breaks below last swing low
    var int bos_dir = 0
    bull_bos = not na(sh0) and tf_close > sh0 and tf_close1 <= sh0
    bear_bos = not na(sl0) and tf_close < sl0 and tf_close1 >= sl0

    if bull_bos
        bos_dir := 1
    if bear_bos
        bos_dir := -1

    bos_score = bos_dir * 2.0

    // --- FVG Detection & Respect/Disrespect ---
    tf_h2 = request.security(syminfo.tickerid, tf, high[2])
    tf_l2 = request.security(syminfo.tickerid, tf, low[2])
    tf_c1 = request.security(syminfo.tickerid, tf, close[1])
    tf_o1 = request.security(syminfo.tickerid, tf, open[1])

    bull_fvg = tf_low > tf_h2 and tf_c1 > tf_o1
    bear_fvg = tf_high < tf_l2 and tf_c1 < tf_o1

    var float last_bull_fvg_top = na
    var float last_bull_fvg_bot = na
    var float last_bear_fvg_top = na
    var float last_bear_fvg_bot = na

    if bull_fvg
        last_bull_fvg_top := tf_low
        last_bull_fvg_bot := tf_h2
    if bear_fvg
        last_bear_fvg_top := tf_l2
        last_bear_fvg_bot := tf_high

    bull_fvg_respected    = not na(last_bull_fvg_bot) and tf_low <= last_bull_fvg_top and tf_close > last_bull_fvg_bot
    bull_fvg_disrespected = not na(last_bull_fvg_bot) and tf_close < last_bull_fvg_bot
    bear_fvg_respected    = not na(last_bear_fvg_top) and tf_high >= last_bear_fvg_bot and tf_close < last_bear_fvg_top
    bear_fvg_disrespected = not na(last_bear_fvg_top) and tf_close > last_bear_fvg_top

    if bull_fvg_disrespected
        last_bull_fvg_top := na
        last_bull_fvg_bot := na
    if bear_fvg_disrespected
        last_bear_fvg_top := na
        last_bear_fvg_bot := na

    fvg_score = 0.0
    fvg_score += bull_fvg_respected ? 1.5 : bull_fvg_disrespected ? -1.5 : 0.0
    fvg_score += bear_fvg_respected ? -1.5 : bear_fvg_disrespected ? 1.5 : 0.0

    // --- Liquidity Sweeps ---
    // Sweep high = wick above swing high but close below it (bearish signal — grabbed BSL)
    // Sweep low = wick below swing low but close above it (bullish signal — grabbed SSL)
    var int sweep_dir = 0
    sweep_high = not na(sh0) and tf_high > sh0 and tf_close < sh0
    sweep_low  = not na(sl0) and tf_low < sl0 and tf_close > sl0

    if sweep_low
        sweep_dir := 1
    if sweep_high
        sweep_dir := -1

    sweep_score = sweep_dir * 1.5

    // --- Displacement ---
    body = math.abs(tf_close - tf_open)
    range_val = tf_high - tf_low
    displacement = range_val > 0 ? body / range_val : 0.0
    disp_score = displacement > 0.7 ? (tf_close > tf_open ? 0.5 : -0.5) : 0.0

    // --- Composite ---
    total = struct_score + bos_score + fvg_score + sweep_score + disp_score
    final_bias = total > 0.5 ? 1 : total < -0.5 ? -1 : 0

    // Detail flags for table
    fvg_stat = bull_fvg_respected ? 1 : bear_fvg_respected ? -1 : bull_fvg_disrespected ? -2 : bear_fvg_disrespected ? 2 : 0

    [final_bias, fvg_stat, bos_dir, sweep_dir]

// ============================================================================
// CALCULATE EACH TIMEFRAME
// ============================================================================

[d_bias, d_fvg, d_bos, d_sweep]    = calc_bias("D")
[h4_bias, h4_fvg, h4_bos, h4_sweep] = calc_bias("240")
[h1_bias, h1_fvg, h1_bos, h1_sweep] = calc_bias("60")

// ============================================================================
// CURRENT TIMEFRAME BIAS (no request.security — uses raw chart data)
// ============================================================================

ct_ph = ta.pivothigh(high, pivot_len, pivot_len)
ct_pl = ta.pivotlow(low, pivot_len, pivot_len)

var float ct_sh1 = na, var float ct_sh0 = na
var float ct_sl1 = na, var float ct_sl0 = na

if not na(ct_ph)
    ct_sh1 := ct_sh0
    ct_sh0 := ct_ph
if not na(ct_pl)
    ct_sl1 := ct_sl0
    ct_sl0 := ct_pl

ct_hh = not na(ct_sh0) and not na(ct_sh1) and ct_sh0 > ct_sh1
ct_hl = not na(ct_sl0) and not na(ct_sl1) and ct_sl0 > ct_sl1
ct_lh = not na(ct_sh0) and not na(ct_sh1) and ct_sh0 < ct_sh1
ct_ll = not na(ct_sl0) and not na(ct_sl1) and ct_sl0 < ct_sl1

ct_struct = (ct_hh ? 1.0 : ct_lh ? -1.0 : 0.0) + (ct_hl ? 1.0 : ct_ll ? -1.0 : 0.0)

var int ct_bos_dir = 0
if not na(ct_sh0) and close > ct_sh0 and close[1] <= ct_sh0
    ct_bos_dir := 1
if not na(ct_sl0) and close < ct_sl0 and close[1] >= ct_sl0
    ct_bos_dir := -1

ct_bull_fvg = low > high[2] and close[1] > open[1]
ct_bear_fvg = high < low[2] and close[1] < open[1]

var float ct_bfvg_top = na, var float ct_bfvg_bot = na
var float ct_sfvg_top = na, var float ct_sfvg_bot = na

if ct_bull_fvg
    ct_bfvg_top := low
    ct_bfvg_bot := high[2]
if ct_bear_fvg
    ct_sfvg_top := low[2]
    ct_sfvg_bot := high

ct_bfvg_resp = not na(ct_bfvg_bot) and low <= ct_bfvg_top and close > ct_bfvg_bot
ct_bfvg_dis  = not na(ct_bfvg_bot) and close < ct_bfvg_bot
ct_sfvg_resp = not na(ct_sfvg_top) and high >= ct_sfvg_bot and close < ct_sfvg_top
ct_sfvg_dis  = not na(ct_sfvg_top) and close > ct_sfvg_top

if ct_bfvg_dis
    ct_bfvg_top := na
    ct_bfvg_bot := na
if ct_sfvg_dis
    ct_sfvg_top := na
    ct_sfvg_bot := na

ct_fvg_score = (ct_bfvg_resp ? 1.5 : ct_bfvg_dis ? -1.5 : 0.0) + (ct_sfvg_resp ? -1.5 : ct_sfvg_dis ? 1.5 : 0.0)

var int ct_sweep_dir = 0
if not na(ct_sl0) and low < ct_sl0 and close > ct_sl0
    ct_sweep_dir := 1
if not na(ct_sh0) and high > ct_sh0 and close < ct_sh0
    ct_sweep_dir := -1

ct_body = math.abs(close - open)
ct_range = high - low
ct_disp = ct_range > 0 ? ct_body / ct_range : 0.0
ct_disp_score = ct_disp > 0.7 ? (close > open ? 0.5 : -0.5) : 0.0

ct_total = ct_struct + ct_bos_dir * 2.0 + ct_fvg_score + ct_sweep_dir * 1.5 + ct_disp_score
ct_bias = ct_total > 0.5 ? 1 : ct_total < -0.5 ? -1 : 0
ct_fvg_stat = ct_bfvg_resp ? 1 : ct_sfvg_resp ? -1 : ct_bfvg_dis ? -2 : ct_sfvg_dis ? 2 : 0

ct_tf_label = timeframe.period

// ============================================================================
// CURRENT TF FVG VISUALIZATION
// ============================================================================

if show_fvg
    bull_fvg_now = low > high[2] and close[1] > open[1]
    bear_fvg_now = high < low[2] and close[1] < open[1]

    if bull_fvg_now
        box.new(bar_index - 1, low, bar_index + 15, high[2], bgcolor=color.new(bull_color, 85), border_color=color.new(bull_color, 60), border_width=1)
    if bear_fvg_now
        box.new(bar_index - 1, low[2], bar_index + 15, high, bgcolor=color.new(bear_color, 85), border_color=color.new(bear_color, 60), border_width=1)

// ============================================================================
// TABLE
// ============================================================================

pos = switch bias_pos
    "Top Right"    => position.top_right
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    "Bottom Left"  => position.bottom_left
    => position.top_right

f_bias_str(b) => b == 1 ? "BULLISH" : b == -1 ? "BEARISH" : "NEUTRAL"
f_clr(b)      => b == 1 ? bull_color : b == -1 ? bear_color : neutral_clr

f_fvg_str(f) => f == 1 ? "Respected" : f == -1 ? "Respected" : f == 2 ? "Disrespected" : f == -2 ? "Disrespected" : "—"
f_fvg_clr(f) => f == 1 ? bull_color : f == -1 ? bear_color : f == 2 ? bull_color : f == -2 ? bear_color : neutral_clr

f_bos_str(b) => b == 1 ? "Bull BOS" : b == -1 ? "Bear BOS" : "—"
f_bos_clr(b) => b == 1 ? bull_color : b == -1 ? bear_color : neutral_clr

f_sweep_str(s) => s == 1 ? "SSL Swept" : s == -1 ? "BSL Swept" : "—"
f_sweep_clr(s) => s == 1 ? bull_color : s == -1 ? bear_color : neutral_clr

var table tbl = table.new(pos, 5, 6, bgcolor=color.new(#16161f, 0), border_color=color.new(#2a2a3a, 0), border_width=1, frame_color=color.new(#2a2a3a, 0), frame_width=2)

if barstate.islast
    // Header
    table.cell(tbl, 0, 0, "TF", text_color=#a0a0b8, text_size=size.small, bgcolor=color.new(#111118, 0))
    table.cell(tbl, 1, 0, "Bias", text_color=#a0a0b8, text_size=size.small, bgcolor=color.new(#111118, 0))
    table.cell(tbl, 2, 0, "FVG", text_color=#a0a0b8, text_size=size.small, bgcolor=color.new(#111118, 0))
    table.cell(tbl, 3, 0, "Structure", text_color=#a0a0b8, text_size=size.small, bgcolor=color.new(#111118, 0))
    table.cell(tbl, 4, 0, "Sweep", text_color=#a0a0b8, text_size=size.small, bgcolor=color.new(#111118, 0))

    // Current TF (highlighted row)
    table.cell(tbl, 0, 1, ct_tf_label, text_color=#ffd700, text_size=size.small, bgcolor=color.new(#1a1a28, 0))
    table.cell(tbl, 1, 1, f_bias_str(ct_bias), text_color=f_clr(ct_bias), text_size=size.small, bgcolor=color.new(#1a1a28, 0))
    table.cell(tbl, 2, 1, f_fvg_str(ct_fvg_stat), text_color=f_fvg_clr(ct_fvg_stat), text_size=size.tiny, bgcolor=color.new(#1a1a28, 0))
    table.cell(tbl, 3, 1, f_bos_str(ct_bos_dir), text_color=f_bos_clr(ct_bos_dir), text_size=size.tiny, bgcolor=color.new(#1a1a28, 0))
    table.cell(tbl, 4, 1, f_sweep_str(ct_sweep_dir), text_color=f_sweep_clr(ct_sweep_dir), text_size=size.tiny, bgcolor=color.new(#1a1a28, 0))

    // Daily
    table.cell(tbl, 0, 2, "Daily", text_color=#ffffff, text_size=size.small, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 1, 2, f_bias_str(d_bias), text_color=f_clr(d_bias), text_size=size.small, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 2, 2, f_fvg_str(d_fvg), text_color=f_fvg_clr(d_fvg), text_size=size.tiny, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 3, 2, f_bos_str(d_bos), text_color=f_bos_clr(d_bos), text_size=size.tiny, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 4, 2, f_sweep_str(d_sweep), text_color=f_sweep_clr(d_sweep), text_size=size.tiny, bgcolor=color.new(#16161f, 0))

    // 4H
    table.cell(tbl, 0, 3, "4H", text_color=#ffffff, text_size=size.small, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 1, 3, f_bias_str(h4_bias), text_color=f_clr(h4_bias), text_size=size.small, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 2, 3, f_fvg_str(h4_fvg), text_color=f_fvg_clr(h4_fvg), text_size=size.tiny, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 3, 3, f_bos_str(h4_bos), text_color=f_bos_clr(h4_bos), text_size=size.tiny, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 4, 3, f_sweep_str(h4_sweep), text_color=f_sweep_clr(h4_sweep), text_size=size.tiny, bgcolor=color.new(#16161f, 0))

    // 1H
    table.cell(tbl, 0, 4, "1H", text_color=#ffffff, text_size=size.small, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 1, 4, f_bias_str(h1_bias), text_color=f_clr(h1_bias), text_size=size.small, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 2, 4, f_fvg_str(h1_fvg), text_color=f_fvg_clr(h1_fvg), text_size=size.tiny, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 3, 4, f_bos_str(h1_bos), text_color=f_bos_clr(h1_bos), text_size=size.tiny, bgcolor=color.new(#16161f, 0))
    table.cell(tbl, 4, 4, f_sweep_str(h1_sweep), text_color=f_sweep_clr(h1_sweep), text_size=size.tiny, bgcolor=color.new(#16161f, 0))

    // Alignment
    all_bull = d_bias == 1 and h4_bias == 1 and h1_bias == 1
    all_bear = d_bias == -1 and h4_bias == -1 and h1_bias == -1
    align_str = all_bull ? "ALL ALIGNED BULLISH" : all_bear ? "ALL ALIGNED BEARISH" : "MIXED"
    align_clr = all_bull ? bull_color : all_bear ? bear_color : #ffd700

    table.cell(tbl, 0, 5, "", bgcolor=color.new(#111118, 0))
    table.cell(tbl, 1, 5, align_str, text_color=align_clr, text_size=size.tiny, bgcolor=color.new(#111118, 0))
    table.cell(tbl, 2, 5, "", bgcolor=color.new(#111118, 0))
    table.cell(tbl, 3, 5, "", bgcolor=color.new(#111118, 0))
    table.cell(tbl, 4, 5, "", bgcolor=color.new(#111118, 0))
